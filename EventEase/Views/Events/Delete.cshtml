@model EventEase.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<h2>Delete Event</h2>
<hr />

<div class="alert alert-warning">
    Are you sure you want to delete <strong>@Model.Name</strong>?
</div>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">Start Date</dt>
    <dd class="col-sm-9">@Model.StartDate.ToString("dd MMM yyyy")</dd>
    <dt class="col-sm-3">End Date</dt>
    <dd class="col-sm-9">@Model.EndDate.ToString("dd MMM yyyy")</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="EventID" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>