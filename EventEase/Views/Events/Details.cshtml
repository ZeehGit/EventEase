@model EventEase.Models.Event

@{
    ViewData["Title"] = "Event Details";
}

<h2>Event Details</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        @if (!string.IsNullOrEmpty(Model.ImageURL))
        {
            <img src="@Model.ImageURL" alt="@Model.Name" class="img-fluid rounded mb-3" style="max-height:250px;object-fit:cover;" />
        }
        <dl class="row">
            <dt class="col-sm-4">Event Name</dt>
            <dd class="col-sm-8">@Model.Name</dd>
            <dt class="col-sm-4">Start Date</dt>
            <dd class="col-sm-8">@Model.StartDate.ToString("dd MMM yyyy HH:mm")</dd>
            <dt class="col-sm-4">End Date</dt>
            <dd class="col-sm-8">@Model.EndDate.ToString("dd MMM yyyy HH:mm")</dd>
            <dt class="col-sm-4">Description</dt>
            <dd class="col-sm-8">@Model.Description</dd>
        </dl>
        <a asp-action="Edit" asp-route-id="@Model.EventID" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>