@model IEnumerable<EventEase.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Events</h2>
    <a asp-action="Create" class="btn btn-primary">+ Add Event</a>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Image</th>
            <th>Name</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var ev in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(ev.ImageURL))
                    {
                        <img src="@ev.ImageURL" alt="@ev.Name" style="width:60px;height:60px;object-fit:cover;border-radius:6px;" />
                    }
                    else
                    {
                        <span class="text-muted">No image</span>
                    }
                </td>
                <td>@ev.Name</td>
                <td>@ev.StartDate.ToString("dd MMM yyyy")</td>
                <td>@ev.EndDate.ToString("dd MMM yyyy")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@ev.EventID" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@ev.EventID" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@ev.EventID" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>