@model EventEase.Models.Booking

@{
    ViewData["Title"] = "Delete Booking";
}

<h2>Delete Booking</h2>
<hr />

<div class="alert alert-warning">
    Are you sure you want to delete booking <strong>@Model.UniqueBookingRef</strong>?
</div>

<dl class="row">
    <dt class="col-sm-3">Reference</dt>
    <dd class="col-sm-9"><code>@Model.UniqueBookingRef</code></dd>
    <dt class="col-sm-3">Venue</dt>
    <dd class="col-sm-9">@Model.Venue?.Name</dd>
    <dt class="col-sm-3">Event</dt>
    <dd class="col-sm-9">@Model.Event?.Name</dd>
    <dt class="col-sm-3">Booking Date</dt>
    <dd class="col-sm-9">@Model.BookingDate.ToString("dd MMM yyyy")</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="BookingID" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>