@model IEnumerable<EventEase.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Bookings</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Booking</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* Search Bar *@ 
<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group" style="max-width:450px;">
        <input type="text"
               name="searchString"
               value="@ViewData["CurrentFilter"]"
               class="form-control"
               placeholder="Search by Booking ID or Event Name..." />
        <button type="submit" class="btn btn-outline-secondary">Search</button>
        <a asp-action="Index" class="btn btn-outline-danger">Clear</a>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">No bookings found.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var booking in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="row g-0">
                        @* Venue Image *@
                        <div class="col-md-4">
                            @if (!string.IsNullOrEmpty(booking.Venue?.ImageURL))
                            {
                                <img src="@booking.Venue.ImageURL"
                                     class="img-fluid rounded-start"
                                     style="height:100%;object-fit:cover;"
                                     alt="@booking.Venue.Name" />
                            }
                            else
                            {
                                <div class="bg-secondary text-white d-flex align-items-center justify-content-center h-100 rounded-start" style="min-height:120px;">
                                    <span>No Image</span>
                                </div>
                            }
                        </div>
                        @* Booking Info *@
                        <div class="col-md-8">
                            <div class="card-body">
                                <h5 class="card-title">
                                    <code>@booking.UniqueBookingRef</code>
                                </h5>
                                <span class="badge @(booking.Status == "Confirmed" ? "bg-success" : booking.Status == "Cancelled" ? "bg-danger" : "bg-warning text-dark") mb-2">
                                    @booking.Status
                                </span>

                                <hr class="my-2" />

                                <p class="mb-1"><strong>Event:</strong> @booking.Event?.Name</p>
                                <p class="mb-1"><strong>Start:</strong> @booking.Event?.StartDate.ToString("dd MMM yyyy")</p>
                                <p class="mb-1"><strong>End:</strong> @booking.Event?.EndDate.ToString("dd MMM yyyy")</p>

                                <hr class="my-2" />

                                <p class="mb-1"><strong>Venue:</strong> @booking.Venue?.Name</p>
                                <p class="mb-1"><strong>Location:</strong> @booking.Venue?.Location</p>
                                <p class="mb-1"><strong>Capacity:</strong> @booking.Venue?.Capacity</p>

                                <hr class="my-2" />

                                <p class="mb-1"><strong>Booking Date:</strong> @booking.BookingDate.ToString("dd MMM yyyy")</p>
                                <p class="mb-1"><strong>Created By:</strong> @booking.CreatedBy</p>

                                <div class="mt-3">
                                    <a asp-action="Details" asp-route-id="@booking.BookingID" class="btn btn-sm btn-info">Details</a>
                                    <a asp-action="Edit" asp-route-id="@booking.BookingID" class="btn btn-sm btn-warning">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@booking.BookingID" class="btn btn-sm btn-danger">Delete</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}